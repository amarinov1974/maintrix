# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cmms_db?schema=public"

# Server
PORT=3000
NODE_ENV=development

# Session
SESSION_SECRET=your-secret-key-change-in-production
# How long an idle session stays valid (sliding expiry). Default 10.
# Cookie maxAge is derived from this; in production also: secure=true, sameSite=none.
# SESSION_TIMEOUT_MINUTES=10

# Redis (session store). Required.
REDIS_URL=redis://localhost:6379

# QR
QR_EXPIRATION_MINUTES=5

# Production (Railway) - set FRONTEND_URL to your frontend's public URL for CORS
# FRONTEND_URL=https://your-frontend.up.railway.app

# Optional: Gate (username/password before demo login). If both are set, entry screen is protected.
# GATE_USERNAME=admin
# GATE_PASSWORD=your-secure-password

# Optional: API key. If set, all requests (except /health) require x-api-key header.
# API_KEY=your-secret-api-key
