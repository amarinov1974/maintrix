{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "rootDir": ".",
    "noEmit": true,
    /* Relaxed only for test project: vi.fn() mocks vs strict callback typing */
    "strictFunctionTypes": false
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
