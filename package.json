{
  "name": "cmms-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --workspace=@maintrix/backend\" \"npm run dev --workspace=@maintrix/frontend\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "db:migrate": "npm run db:migrate --workspace=@maintrix/backend",
    "db:seed": "npm run db:seed --workspace=@maintrix/backend",
    "db:studio": "npm run db:studio --workspace=@maintrix/backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.3.3"
  }
}
